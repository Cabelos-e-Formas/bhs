---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { Image } from "astro:assets";
import LogoImg from "../assets/bhs-logo.png";
import { getLangFromUrl } from "../i18n/utils";
import "../styles/global.css";

const reader = createReader(process.cwd(), keystaticConfig);
const lang = getLangFromUrl(Astro.url);

const data = await reader.singletons.linktree.read();
const profileName = data?.profile_name ?? "Brazilian Hair Studio";
const taglineKey = `tagline_${lang}` as keyof typeof data;
const tagline = (data?.[taglineKey] as string | undefined) ?? data?.tagline_en ?? "Modern Brazilian techniques · Fort Myers, Florida";

const linksRaw = await reader.collections.linktreeLinks.all();
const links = linksRaw
  .sort((a, b) => a.entry.order.localeCompare(b.entry.order))
  .map(({ entry }) => {
    const label: string = entry[`label_${lang}` as keyof typeof entry] as string ?? entry.label_en ?? '';
    return { entry, label };
  });

const iconMap: Record<string, string> = {
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>`,
  google: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>`,
  website: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3.6 9h16.8M3.6 15h16.8M12 3a14.5 14.5 0 0 1 0 18M12 3a14.5 14.5 0 0 0 0 18"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
};

const locales = [
  { code: "en", label: "EN", href: "/linktree" },
  { code: "pt", label: "PT", href: "/pt/linktree" },
  { code: "sp", label: "ES", href: "/sp/linktree" },
];
---

<!DOCTYPE html>
<html lang={lang} class="noise">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0e3b31" />
    <title>{profileName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <style>
      body {
        background-color: #0e3b31;
      }
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(255,255,255,0.04) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }
      main {
        position: relative;
        z-index: 1;
      }
      .ltree-link {
        position: relative;
        overflow: hidden;
        min-height: 56px;
      }
      .ltree-link::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(237,235,223,0.04) 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
        border-radius: inherit;
      }
      .ltree-link:hover::before {
        opacity: 1;
      }
      .ltree-link:focus-visible {
        outline: 2px solid rgba(237,235,223,0.5);
        outline-offset: 3px;
      }
      .lang-switch:focus-visible {
        outline: 2px solid rgba(237,235,223,0.5);
        outline-offset: 4px;
        border-radius: 3px;
      }
    </style>
  </head>
  <body class="min-h-screen">
    <main class="min-h-screen flex flex-col items-center px-5 pt-14 pb-16">
      <div class="w-full max-w-[440px] flex flex-col items-center">

        <!-- Logo -->
        <div class="ltree-item mb-4">
          <Image
            src={LogoImg}
            alt={profileName}
            class="h-[56px] w-auto"
            style="filter: brightness(0) invert(1); opacity: 0.88;"
          />
        </div>

        <!-- Profile name (visible heading for accessibility) -->
        <h1 class="ltree-item sr-only">{profileName}</h1>

        <!-- Language switcher -->
        <nav class="ltree-item mb-7 mt-5" aria-label="Language">
          <ul class="flex items-center gap-4" role="list">
            {locales.map((locale, i) => (
              <li class="flex items-center gap-4">
                <a
                  href={locale.href}
                  lang-switch
                  class="lang-switch"
                  aria-current={lang === locale.code ? "page" : undefined}
                  style={`font-family: Lato, sans-serif; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; font-weight: ${lang === locale.code ? "600" : "400"}; color: ${lang === locale.code ? "#edebdf" : "rgba(237,235,223,0.4)"}; transition: color 0.2s; padding: 4px 2px;`}
                >
                  {locale.label}
                </a>
                {i < locales.length - 1 && (
                  <span aria-hidden="true" style="color: rgba(237,235,223,0.15); font-size: 12px; line-height: 1;">|</span>
                )}
              </li>
            ))}
          </ul>
        </nav>

        <!-- Tagline -->
        <p class="ltree-item text-center" style="color: rgba(237,235,223,0.45); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; font-family: Lato, sans-serif; line-height: 1.6;">
          {tagline}
        </p>

        <!-- Divider -->
        <div class="ltree-item my-8" style="width: 28px; height: 1px; background: rgba(237,235,223,0.2);" role="separator" aria-hidden="true"></div>

        <!-- Links -->
        <ul class="w-full flex flex-col gap-3" role="list">
          {links.map(({ entry, label }) => {
            return (
              <li>
                <a
                  href={entry.url}
                  target={entry.url.startsWith("tel:") ? "_self" : "_blank"}
                  rel={entry.url.startsWith("tel:") ? undefined : "noopener noreferrer"}
                  class="ltree-item ltree-link group flex items-center gap-4 px-5 transition-all duration-300 w-full text-accent-dark"
                  style="background-color: #edebdf; border-radius: 14px; padding-top: 17px; padding-bottom: 17px;"
                >
                  <!-- Icon -->
                  <span
                    class="flex-shrink-0 flex items-center justify-center transition-opacity duration-300 opacity-60 group-hover:opacity-90"
                    aria-hidden="true"
                    set:html={iconMap[entry.icon] ?? iconMap.website}
                  />

                  <!-- Label + subtitle -->
                  <div class="flex-1 min-w-0">
                    <span
                      class="block tracking-wide font-semibold"
                      style="font-family: Lato, sans-serif; font-size: 15px;"
                    >
                      {label}
                    </span>
                    {entry.subtitle && (
                      <span
                        class="block truncate mt-0.5"
                        style="font-family: Lato, sans-serif; font-size: 12px; letter-spacing: 0.03em; opacity: 0.5;"
                      >
                        {entry.subtitle}
                      </span>
                    )}
                  </div>

                  <!-- Arrow -->
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="flex-shrink-0 transition-all duration-300 group-hover:translate-x-0.5 opacity-35 group-hover:opacity-65"
                    style="width: 16px; height: 16px;"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </a>
              </li>
            );
          })}
        </ul>

        <!-- Bottom handle -->
        <p
          class="ltree-item mt-10"
          style="font-family: Lato, sans-serif; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(237,235,223,0.3);"
          aria-label="Instagram: @brazilian.hairstudio"
        >
          @brazilian.hairstudio
        </p>
      </div>
    </main>
  </body>
</html>

<script>
  import { gsap } from "gsap";

  gsap.from(".ltree-item", {
    opacity: 0,
    y: 18,
    duration: 0.55,
    stagger: 0.07,
    ease: "power3.out",
    delay: 0.05,
    clearProps: "opacity,transform",
  });
</script>
